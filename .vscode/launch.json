{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/extension"],
      "preLaunchTask": "npm: compile (extension)",
      "outFiles": ["${workspaceFolder}/extension/out/**/*.js"]
    }
  ]
}
